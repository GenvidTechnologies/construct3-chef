{
	"$schema": "../aces.schema.json",
	"account": {
		"conditions": [
			{
				"id": "is-logged-in",
				"scriptName": "IsLoggedIn",
				"params": []
			},
			{
				"id": "login",
				"scriptName": "IsLoggingIn",
				"params": []
			}
		],
		"actions": [
			{
				"id": "login",
				"scriptName": "Login",
				"params": [
					{ "id": "token", "type": "string" },
					{ "id": "region", "type": "string" }
				]
			},
			{
				"id": "logout",
				"scriptName": "Logout",
				"params": []
			},
			{
				"id": "sync",
				"scriptName": "Sync",
				"params": []
			}
		],
		"expressions": [
			{
				"id": "session-length",
				"expressionName": "SessionLength",
				"returnType": "number",
				"params": [{ "id": "format", "type": "string" }]
			},
			{
				"id": "rank",
				"expressionName": "Rank",
				"returnType": "number",
				"params": []
			}
		]
	}
}
